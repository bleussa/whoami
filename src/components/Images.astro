---
interface Image {
    path: string;
    title?: string;
    size?: number;
    link?: string;
}

interface Props {
    images: Image[];
}

const { images } = Astro.props;

// Distribute sizes: explicit sizes claim their %, the rest split what remains equally
const totalExplicit = images.reduce((sum, img) => sum + (img.size ?? 0), 0);
const withoutSize = images.filter(img => img.size === undefined).length;
const defaultSize = withoutSize > 0 ? (110 - totalExplicit) / withoutSize : 110 / images.length;
const computedSizes = images.map(img => img.size ?? defaultSize);
---

<div class="images-stage">
    {
        images.map((image, index) => {
            const sign = Math.random() > 0.5 ? 1 : -1;
            const rot = (sign * (1 + Math.random() * 2)).toFixed(2);
            const titleRot = ((Math.random() * 4) - 2).toFixed(2);
            const titleFontSize = (1.618 * 16 * (0.8 + Math.random() * 0.4)).toFixed(1);

            return (
                <div class="photo" style={`--rot:${rot}deg;`} data-size-pct={computedSizes[index].toFixed(4)}>
                    <div class="rotate-handle" />
                    <img
                        src={image.path}
                        alt={`${index + 1}`}
                        draggable="false"
                    />
                    <p style={`--title-rot:${titleRot}deg; font-size:${titleFontSize}px;`}>{image.title}</p>
                    {image.link && <a class="link-dot" href={image.link} target="_blank" rel="noopener noreferrer" />}
                    <div class="resize-handle" />
                </div>
            );
        })
    }
</div>

<script>
    window.addEventListener("load", init);
    if (document.readyState === "complete") init();

    function init() {
        let rotating: HTMLElement | null = null;
        let rotateCX = 0;
        let rotateCY = 0;
        let rotateStartAngle = 0;
        let rotateStartRot = 0;

        let resizing: HTMLElement | null = null;
        let resizeStartX = 0;
        let resizeStartW = 0;
        let resizeBaseW = 0;

        let active: HTMLElement | null = null;
        let startMouseX = 0;
        let startMouseY = 0;
        let startElX = 0;
        let startElY = 0;
        let didMove = false;

        function getPos(el: HTMLElement) {
            return {
                x: parseFloat(el.dataset.x ?? "0"),
                y: parseFloat(el.dataset.y ?? "0"),
            };
        }

        function applyTransform(el: HTMLElement, x: number, y: number) {
            const rot = el.style.getPropertyValue("--rot") || "0deg";
            el.style.transform = `translate(${x}px, ${y}px) rotate(${rot})`;
            el.style.left = "0";
            el.style.top = "0";
            el.dataset.x = String(x);
            el.dataset.y = String(y);
        }

        function applyRotation(el: HTMLElement, deg: number) {
            const baseRot = parseFloat(el.dataset.baseRot ?? "0");
            const clamped = Math.max(baseRot - 7, Math.min(baseRot + 7, deg));
            el.style.setProperty("--rot", clamped + "deg");
            const pos = getPos(el);
            applyTransform(el, pos.x, pos.y);
        }

        // ── Init each stage independently ────────────────────────────────────
        const stages = Array.from(
            document.querySelectorAll<HTMLElement>(".images-stage"),
        );
        if (!stages.length) return;

        stages.forEach((stage) => {
            const photos = Array.from(
                stage.querySelectorAll<HTMLElement>(".photo"),
            );
            if (!photos.length) return;

            const cw = stage.offsetWidth;
            const margin = 40 / 1.618;

            // ── Pass 1: set widths and measure heights ────────────────────────
            const heights = photos.map((el) => {
                const sizePct = parseFloat(el.dataset.sizePct ?? "");
                const w = !isNaN(sizePct) ? cw * (sizePct / 100) * 0.9 : cw / photos.length * 0.9;
                el.style.width = w + "px";
                el.dataset.baseW = String(w);
                return el.offsetHeight || Math.round(w * 1.35);
            });

            // ── Set stage height based on tallest image ───────────────────────
            const maxH = Math.max(...heights);
            const ch = maxH + margin * 2;
            stage.style.height = ch + "px";

            // ── Pass 2: scatter ───────────────────────────────────────────────
            let cumX = 0;
            photos.forEach((el, i) => {
                const sizePct = parseFloat(el.dataset.sizePct ?? "");
                const slotW_i = !isNaN(sizePct) ? cw * (sizePct / 100) : cw / photos.length;
                const w = el.offsetWidth;
                const h = heights[i];
                const jitter = (Math.random() - 0.5) * slotW_i * 0.16;
                const x = Math.max(0, Math.min(cw - w, cumX + slotW_i * 0.5 - w / 2 + jitter));
                const y = margin + Math.random() * Math.max(0, ch - h - margin * 2);
                el.dataset.baseRot = String(parseFloat(el.style.getPropertyValue("--rot") || "0"));
                applyTransform(el, x, y);
                cumX += slotW_i;
            });

            // ── Rotate handles ────────────────────────────────────────────────
            photos.forEach((el) => {
                const handle = el.querySelector<HTMLElement>(".rotate-handle");
                if (!handle) return;

                const startRotate = (clientX: number, clientY: number) => {
                    const rect = el.getBoundingClientRect();
                    rotateCX = rect.left + rect.width / 2;
                    rotateCY = rect.top + rect.height / 2;
                    rotateStartAngle = Math.atan2(
                        clientY - rotateCY,
                        clientX - rotateCX,
                    );
                    rotateStartRot = parseFloat(
                        el.style.getPropertyValue("--rot") || "0",
                    );
                    rotating = el;
                };

                handle.addEventListener("mousedown", (e: MouseEvent) => {
                    e.stopPropagation();
                    e.preventDefault();
                    startRotate(e.clientX, e.clientY);
                });

                handle.addEventListener(
                    "touchstart",
                    (e: TouchEvent) => {
                        e.stopPropagation();
                        e.preventDefault();
                        const t = e.touches[0];
                        startRotate(t.clientX, t.clientY);
                    },
                    { passive: false },
                );
            });

            // ── Resize handles ────────────────────────────────────────────────
            photos.forEach((el) => {
                const handle = el.querySelector<HTMLElement>(".resize-handle");
                if (!handle) return;

                handle.addEventListener("mousedown", (e: MouseEvent) => {
                    e.stopPropagation();
                    e.preventDefault();
                    resizing = el;
                    resizeStartX = e.clientX;
                    resizeStartW = el.offsetWidth;
                    resizeBaseW = parseFloat(
                        el.dataset.baseW ?? String(el.offsetWidth),
                    );
                });

                handle.addEventListener(
                    "touchstart",
                    (e: TouchEvent) => {
                        e.stopPropagation();
                        e.preventDefault();
                        const t = e.touches[0];
                        resizing = el;
                        resizeStartX = t.clientX;
                        resizeStartW = el.offsetWidth;
                        resizeBaseW = parseFloat(
                            el.dataset.baseW ?? String(el.offsetWidth),
                        );
                    },
                    { passive: false },
                );
            });

            // ── Link dot: prevent drag from starting ─────────────────────────
            photos.forEach((el) => {
                const dot = el.querySelector<HTMLElement>(".link-dot");
                if (!dot) return;
                dot.addEventListener("mousedown", (e) => e.stopPropagation());
                dot.addEventListener("touchstart", (e) => e.stopPropagation(), { passive: true });
            });

            // ── Drag ──────────────────────────────────────────────────────────
            photos.forEach((el) => {
                if (el.tagName === "A") {
                    el.addEventListener("click", (e) => e.preventDefault());
                }

                el.addEventListener("mousedown", (e: MouseEvent) => {
                    if (e.button !== 0) return;
                    e.preventDefault();
                    active = el;
                    didMove = false;
                    startMouseX = e.clientX;
                    startMouseY = e.clientY;
                    const pos = getPos(el);
                    startElX = pos.x;
                    startElY = pos.y;
                    el.classList.add("is-dragging");
                });

                el.addEventListener(
                    "touchstart",
                    (e: TouchEvent) => {
                        e.preventDefault();
                        const t = e.touches[0];
                        active = el;
                        didMove = false;
                        startMouseX = t.clientX;
                        startMouseY = t.clientY;
                        const pos = getPos(el);
                        startElX = pos.x;
                        startElY = pos.y;
                        el.classList.add("is-dragging");
                    },
                    { passive: false },
                );
            });
        });

        // ── Global move / end handlers (shared across all stages) ────────────
        window.addEventListener("mousemove", (e: MouseEvent) => {
            if (rotating) {
                const angle = Math.atan2(
                    e.clientY - rotateCY,
                    e.clientX - rotateCX,
                );
                const delta = (angle - rotateStartAngle) * (180 / Math.PI);
                applyRotation(rotating, rotateStartRot + delta);
                return;
            }
            if (resizing) {
                const dx = e.clientX - resizeStartX;
                const min = resizeBaseW * 0.75;
                const max = resizeBaseW * 1.25;
                resizing.style.width =
                    Math.max(min, Math.min(max, resizeStartW + dx)) + "px";
                return;
            }
            if (!active) return;
            const dx = e.clientX - startMouseX;
            const dy = e.clientY - startMouseY;
            if (Math.abs(dx) > 3 || Math.abs(dy) > 3) didMove = true;
            applyTransform(active, startElX + dx, startElY + dy);
        });

        window.addEventListener("mouseup", () => {
            if (rotating) {
                rotating = null;
                return;
            }
            if (resizing) {
                resizing = null;
                return;
            }
            if (!active) return;
            active.classList.remove("is-dragging");
            active = null;
            didMove = false;
        });

        window.addEventListener(
            "touchmove",
            (e: TouchEvent) => {
                const t = e.touches[0];
                if (rotating) {
                    e.preventDefault();
                    const angle = Math.atan2(
                        t.clientY - rotateCY,
                        t.clientX - rotateCX,
                    );
                    const delta = (angle - rotateStartAngle) * (180 / Math.PI);
                    applyRotation(rotating, rotateStartRot + delta);
                    return;
                }
                if (resizing) {
                    e.preventDefault();
                    const dx = t.clientX - resizeStartX;
                    const min = resizeBaseW * 0.75;
                    const max = resizeBaseW * 1.25;
                    resizing.style.width =
                        Math.max(min, Math.min(max, resizeStartW + dx)) + "px";
                    return;
                }
                if (!active) return;
                e.preventDefault();
                const dx = t.clientX - startMouseX;
                const dy = t.clientY - startMouseY;
                if (Math.abs(dx) > 3 || Math.abs(dy) > 3) didMove = true;
                applyTransform(active, startElX + dx, startElY + dy);
            },
            { passive: false },
        );

        window.addEventListener("touchend", () => {
            if (rotating) {
                rotating = null;
                return;
            }
            if (resizing) {
                resizing = null;
                return;
            }
            if (!active) return;
            active.classList.remove("is-dragging");
            active = null;
            didMove = false;
        });
    }
</script>
